# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-3-5-haiku-20241022 — fast and cheap)
# Other options: claude-3-5-sonnet-20241022 (smarter, slower, more expensive)
LLM_MODEL=claude-3-5-haiku-20241022

# Port the MCP server listens on (default: 3333)
MCP_PORT=3333
