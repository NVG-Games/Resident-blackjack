# ── Supabase (Lobby / Multiplayer room discovery) ─────────────────────────────
#
# Required for the online multiplayer lobby to work.
# Create a free project at https://supabase.com, then copy the values from
# Project Settings → API.
# After creating the project, run supabase/migrations/001_rooms.sql in the
# Supabase SQL Editor to create the rooms table.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram Mini App ─────────────────────────────────────────────────────────
#
# Username of your Telegram bot (without the @).
# Used to generate invite deep-links: t.me/<BOT_USERNAME>?startapp=ROOM-CODE
# Create a bot at https://t.me/BotFather, then set the menu button URL to your
# deployed app URL (GitHub Pages or your own domain).

VITE_TG_BOT_USERNAME=your_bot_username

# ── P2P Multiplayer (PeerJS) ─────────────────────────────────────────────────
#
# Leave all VITE_PEER_* variables EMPTY to use the public PeerJS cloud server.
# Set them to point at the self-hosted peerjs-server sidecar (see compose.yaml).
#
# When running via Docker Compose the sidecar is available at localhost:9000.
# For production, replace with your domain / IP.

# Hostname of the PeerJS signalling server (no protocol, no port).
# Example for self-hosted:  VITE_PEER_HOST=localhost
# Leave empty for public cloud:
VITE_PEER_HOST=

# Port of the PeerJS signalling server. Default: 9000
VITE_PEER_PORT=9000

# URL path prefix of the PeerJS server. Default: /
VITE_PEER_PATH=/
